# App
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3010
NEXTAUTH_SECRET=replace-with-a-long-random-string
SEED_ON_BOOT=true
HARMONIZING_IMPORTS_DIR=/Users/andresbarcenas/Downloads

# Database
DATABASE_URL=postgresql://harmonizing:harmonizing@postgres:5432/harmonizing

# Media storage
# Local Docker uses S3/MinIO. Vercel production uses vercel-blob with BLOB_READ_WRITE_TOKEN.
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=harmonizing-media
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:9010/harmonizing-media
LOCAL_STORAGE_DIR=public/uploads/videos
LOCAL_REPERTOIRE_STORAGE_DIR=public/uploads/repertoire
BLOB_READ_WRITE_TOKEN=

# Mail
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@harmonizing.local
NOTIFICATION_SMTP_MIRROR=false
RESEND_API_KEY=
RESEND_FROM_EMAIL="Harmonizing Academy <no-reply@harmonizing.app>"
CLASS_EMAIL_REMINDERS_ENABLED=true
CLASS_REMINDER_OFFSETS_MINUTES=1440,60
CLASS_REMINDER_WINDOW_MINUTES=20

# Alegra (invoicing read-only sync)
ALEGRA_API_BASE_URL=https://api.alegra.com/api/v1
ALEGRA_API_EMAIL=
ALEGRA_API_TOKEN=
INVOICE_SYNC_HOURS=6
CRON_SECRET=replace-with-a-long-random-cron-secret
