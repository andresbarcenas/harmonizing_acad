generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

// Compatibility enums reserved for naming convergence in future refactors.
enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  RESCHEDULE_PENDING
  CANCELLED
}

// Compatibility enum reserved for naming convergence in future refactors.
enum ClassStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  RESCHEDULE_PENDING
  CANCELLED
}

enum ClassSessionType {
  RECURRING
  SINGLE
  TRIAL
  MAKEUP
  EXTRA
  EVALUATION
  REPLACEMENT
}

enum RecurringTimezoneMode {
  STUDENT_TIME
  TEACHER_TIME
  CUSTOM_TIMEZONE
}

enum RescheduleStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ClassRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum VideoStatus {
  PENDING
  REVIEWED
  FEEDBACK_GIVEN
}

enum NotificationType {
  CLASS_REMINDER
  RESCHEDULE_UPDATE
  VIDEO_REVIEW
  MESSAGE
  SYSTEM
}

enum RepertoireAttachmentType {
  SHEET_MUSIC
}

enum ClassReminderChannel {
  EMAIL
}

enum ClassReminderStatus {
  SENT
  FAILED
  SKIPPED
}

enum ConsentSignerRole {
  PARENT_GUARDIAN
}

enum ConsentEmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum StudentLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum LogEntryType {
  NOTE
  FEEDBACK
  ATTENDANCE
  GOAL_UPDATE
  MILESTONE
}

enum RepertoireStatus {
  ASSIGNED
  LEARNING
  IMPROVING
  PERFORMANCE_READY
  COMPLETED
  PAUSED
}

enum PracticeAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  REVIEWED
  OVERDUE
}

enum ProgressReportStatus {
  DRAFT
  GENERATED
  FINALIZED
  PUBLISHED
  ARCHIVED
}

enum HistoricalImportBatchStatus {
  STAGED
  REVIEWING
  APPLIED
  CANCELLED
  FAILED
}

enum HistoricalImportRowStatus {
  STAGED
  APPROVED
  APPLIED
  SKIPPED
  SOURCE_ONLY
  ERROR
}

enum HistoricalImportSuggestionType {
  STUDENT_LOG
  LESSON_NOTE
  REPERTOIRE
  PRACTICE_ASSIGNMENT
  PROGRESS_REPORT
  SKILL_EVIDENCE
  SOURCE_ONLY
  UNKNOWN
}

enum InvoiceContactLinkStrategy {
  EMAIL_AUTO
  MANUAL
}

enum InvoiceSyncScope {
  STUDENT
  ALL
}

enum InvoiceSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role
  locale        String    @default("en")
  timezone      String    @default("America/New_York")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                 Account[]
  sessions                 Session[]
  studentProfile           StudentProfile?
  teacherProfile           TeacherProfile?
  sentMessages             Message[]         @relation("MessageSender")
  notifications            Notification[]
  progressUpdates          ProgressRecord[]  @relation("ProgressUpdatedBy")
  triggeredInvoiceSyncRuns InvoiceSyncRun[]  @relation("InvoiceSyncTriggeredBy")
  studentLogEntries        StudentLogEntry[] @relation("StudentLogAuthor")
  sentInvitations          Invitation[]      @relation("InvitationSender")
  acceptedInvitations      Invitation[]      @relation("InvitationAcceptedBy")
  generatedProgressReports ProgressReport[]  @relation("ProgressReportGeneratedBy")
  publishedProgressReports ProgressReport[]  @relation("ProgressReportPublishedBy")
  requestedClassRequests   ClassRequest[]    @relation("ClassRequestRequestedBy")
  reviewedClassRequests    ClassRequest[]    @relation("ClassRequestReviewedBy")
  historicalImportBatches  HistoricalImportBatch[] @relation("HistoricalImportCreatedBy")
  reviewedImportRows       HistoricalImportRow[]   @relation("HistoricalImportRowReviewedBy")
  uploadedRepertoireAttachments RepertoireAttachment[] @relation("RepertoireAttachmentUploadedBy")
  classReminderDeliveries       ClassReminderDelivery[] @relation("ClassReminderRecipient")
  consentSignatures             ConsentSignature[] @relation("ConsentSignedUser")
  createdRepertoireCatalogItems RepertoireCatalogItem[] @relation("RepertoireCatalogCreatedBy")

  @@index([role])
}

model StudentProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  phone               String?
  bio                 String?
  preferredInstrument String?
  joinedAt            DateTime @default(now())

  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment          TeacherAssignment?
  subscriptions       ActiveSubscription[]
  sessions            ClassSession[]         @relation("SessionStudent")
  practiceVideos      PracticeVideo[]
  progressRecords     ProgressRecord[]
  learnedSongs        LearnedSong[]
  goals               Goal[]
  studentThreads      MessageThread[]        @relation("ThreadStudent")
  recurringSeries     RecurringClassSeries[]
  invoices            Invoice[]
  invoiceContactLink  InvoiceContactLink?
  invoiceSyncRuns     InvoiceSyncRun[]
  logEntries          StudentLogEntry[]
  invitations         Invitation[]
  lessonNotes         LessonNote[]
  repertoireItems     RepertoireItem[]
  practiceAssignments PracticeAssignment[]
  practiceLogs        PracticeLog[]
  progressReports     ProgressReport[]
  classRequests       ClassRequest[]
  historicalImportBatches HistoricalImportBatch[]
  historicalImportRows    HistoricalImportRow[]
}

model TeacherProfile {
  id              String        @id @default(cuid())
  userId          String        @unique
  specialty       String
  bio             String?
  zoomLink        String?
  meetLink        String?
  status          TeacherStatus @default(ACTIVE)
  statusUpdatedAt DateTime      @default(now())

  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  students            TeacherAssignment[]
  sessions            ClassSession[]         @relation("SessionTeacher")
  availability        TeacherAvailability[]
  rescheduleRequests  RescheduleRequest[]    @relation("RequestHandledBy")
  videosToReview      PracticeVideo[]        @relation("VideoTeacher")
  videoFeedback       VideoFeedback[]
  teacherThreads      MessageThread[]        @relation("ThreadTeacher")
  recurringSeries     RecurringClassSeries[]
  lessonNotes         LessonNote[]
  repertoireItems     RepertoireItem[]
  practiceAssignments PracticeAssignment[]
  progressReports     ProgressReport[]
  classRequests       ClassRequest[]
}

model TeacherAssignment {
  id         String   @id @default(cuid())
  studentId  String   @unique
  teacherId  String
  assignedAt DateTime @default(now())
  assignedBy String?

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}

model SubscriptionPlan {
  id                String   @id @default(cuid())
  name              String
  priceUsd          Int
  monthlyClassCount Int
  description       String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  enrollments ActiveSubscription[]
}

model ActiveSubscription {
  id                String    @id @default(cuid())
  studentId         String
  planId            String
  startsAt          DateTime
  endsAt            DateTime?
  monthlyClassLimit Int
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())

  student StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  plan    SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([studentId, active])
}

model ClassSession {
  id                 String           @id @default(cuid())
  studentId          String
  teacherId          String
  recurrenceId       String?
  classRequestId     String?          @unique
  type               ClassSessionType @default(SINGLE)
  startsAtUtc        DateTime
  endsAtUtc          DateTime
  meetingUrl         String
  status             SessionStatus    @default(SCHEDULED)
  timezone           String           @default("America/New_York")
  instrument         String?
  locationMode       String           @default("ONLINE")
  lessonFocus        String?
  lastClassNotes     String?
  internalNote       String?
  studentVisibleNote String?
  completedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  student             StudentProfile        @relation("SessionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher             TeacherProfile        @relation("SessionTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  recurrence          RecurringClassSeries? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  classRequest        ClassRequest?         @relation("ClassRequestCreatedSession", fields: [classRequestId], references: [id], onDelete: SetNull)
  rescheduleRequests  RescheduleRequest[]
  lessonNote          LessonNote?
  practiceAssignments PracticeAssignment[]
  reminderDeliveries  ClassReminderDelivery[]

  @@index([teacherId, startsAtUtc])
  @@index([studentId, startsAtUtc])
  @@index([recurrenceId, startsAtUtc])
  @@index([type, startsAtUtc])
}

model RecurringClassSeries {
  id               String    @id @default(cuid())
  studentId        String
  teacherId        String
  timezone         String
  timezoneMode     RecurringTimezoneMode @default(STUDENT_TIME)
  startsOnDate     DateTime
  startTimeLocal   String
  startMinuteLocal Int
  durationMin      Int
  intervalWeeks    Int
  horizonWeeks     Int
  weekdays         Int[]
  meetingUrl       String
  lessonFocus      String?
  active           Boolean   @default(true)
  stoppedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  student  StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher  TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  sessions ClassSession[]

  @@index([teacherId, active, createdAt])
  @@index([studentId, createdAt])
}

model TeacherAvailability {
  id               String   @id @default(cuid())
  teacherId        String
  weekday          Int
  startMinuteLocal Int
  endMinuteLocal   Int
  timezone         String
  createdAt        DateTime @default(now())

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, weekday])
}

model RescheduleRequest {
  id               String           @id @default(cuid())
  sessionId        String
  requestedById    String
  reviewedById     String?
  proposedStartUtc DateTime
  proposedEndUtc   DateTime
  studentMessage   String?
  teacherResponse  String?
  status           RescheduleStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  decidedAt        DateTime?

  session    ClassSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reviewedBy TeacherProfile? @relation("RequestHandledBy", fields: [reviewedById], references: [id])

  @@index([sessionId, status])
}

model ClassRequest {
  id                String             @id @default(cuid())
  studentId         String
  teacherId         String
  requestedByUserId String
  reviewedByUserId  String?
  type              ClassSessionType
  status            ClassRequestStatus @default(PENDING)
  preferredStartUtc DateTime
  preferredEndUtc   DateTime
  timezone          String             @default("America/New_York")
  durationMin       Int
  studentMessage    String?
  reviewerResponse  String?
  internalNote      String?
  rejectionReason   String?
  decidedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher        TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  requestedBy    User           @relation("ClassRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedBy     User?          @relation("ClassRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdSession ClassSession?  @relation("ClassRequestCreatedSession")

  @@index([studentId, status, createdAt])
  @@index([teacherId, status, createdAt])
  @@index([preferredStartUtc])
  @@index([type, status])
}

model PracticeVideo {
  id                   String      @id @default(cuid())
  studentId            String
  teacherId            String
  practiceAssignmentId String?
  repertoireItemId     String?
  skillCategoryId      String?
  storageKey           String
  originalName         String
  durationSec          Int
  status               VideoStatus @default(PENDING)
  submittedAt          DateTime    @default(now())
  reviewedAt           DateTime?

  student            StudentProfile      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher            TeacherProfile      @relation("VideoTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  practiceAssignment PracticeAssignment? @relation(fields: [practiceAssignmentId], references: [id], onDelete: SetNull)
  repertoireItem     RepertoireItem?     @relation(fields: [repertoireItemId], references: [id], onDelete: SetNull)
  skillCategory      SkillCategory?      @relation(fields: [skillCategoryId], references: [id], onDelete: SetNull)
  feedback           VideoFeedback[]

  @@index([teacherId, status])
  @@index([studentId, submittedAt])
  @@index([practiceAssignmentId])
  @@index([repertoireItemId])
  @@index([skillCategoryId])
}

model VideoFeedback {
  id         String   @id @default(cuid())
  videoId    String
  teacherId  String
  comment    String
  reviewedAt DateTime @default(now())

  video        PracticeVideo      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  teacher      TeacherProfile     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  skillRatings VideoSkillRating[]

  @@index([videoId])
}

model LessonNote {
  id                  String   @id @default(cuid())
  sessionId           String   @unique
  studentId           String
  teacherId           String
  summary             String
  taughtToday         String?
  studentDidWell      String?
  needsImprovement    String?
  homework            String?
  nextLessonFocus     String?
  teacherPrivateNote  String?
  studentVisibleNote  String?
  preparednessRating  Int?
  focusRating         Int?
  effortRating        Int?
  overallLessonRating Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  session             ClassSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student             StudentProfile       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher             TeacherProfile       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  skillRatings        LessonSkillRating[]
  practiceAssignments PracticeAssignment[]

  @@index([studentId, createdAt])
  @@index([teacherId, createdAt])
}

model SkillCategory {
  id          String   @id @default(cuid())
  name        String
  instrument  String   @default("GENERAL")
  description String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessonRatings       LessonSkillRating[]
  practiceAssignments PracticeAssignment[]
  practiceLogs        PracticeLog[]
  practiceVideos      PracticeVideo[]
  videoSkillRatings   VideoSkillRating[]

  @@unique([instrument, name])
  @@index([instrument, active, sortOrder])
}

model LessonSkillRating {
  id              String   @id @default(cuid())
  lessonNoteId    String
  skillCategoryId String
  rating          Int
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lessonNote    LessonNote    @relation(fields: [lessonNoteId], references: [id], onDelete: Cascade)
  skillCategory SkillCategory @relation(fields: [skillCategoryId], references: [id], onDelete: Cascade)

  @@unique([lessonNoteId, skillCategoryId])
  @@index([skillCategoryId])
}

model RepertoireItem {
  id                  String           @id @default(cuid())
  studentId           String
  teacherId           String?
  catalogItemId        String?
  title               String
  composerOrArtist    String?
  instrument          String
  level               String?
  status              RepertoireStatus @default(ASSIGNED)
  startDate           DateTime?
  targetDate          DateTime?
  completedDate       DateTime?
  masteryPercent      Int              @default(0)
  currentFocusSection String?
  currentTempo        Int?
  targetTempo         Int?
  teacherNotes        String?
  studentVisibleNotes String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  student             StudentProfile       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher             TeacherProfile?      @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  catalogItem         RepertoireCatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  practiceAssignments PracticeAssignment[]
  practiceLogs        PracticeLog[]
  practiceVideos      PracticeVideo[]
  attachments         RepertoireAttachment[]

  @@index([studentId, status])
  @@index([teacherId, status])
  @@index([studentId, catalogItemId])
}

model RepertoireCatalogItem {
  id                         String   @id @default(cuid())
  title                      String
  composerOrArtist           String?
  instrument                  String
  level                      String?
  defaultFocusSection        String?
  defaultCurrentTempo        Int?
  defaultTargetTempo         Int?
  defaultTeacherNotes        String?
  defaultStudentVisibleNotes String?
  tags                       String?
  active                     Boolean  @default(true)
  createdByUserId            String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  createdBy       User?            @relation("RepertoireCatalogCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  repertoireItems RepertoireItem[]

  @@index([instrument, active, title])
  @@index([createdByUserId, createdAt])
}

model RepertoireAttachment {
  id               String                   @id @default(cuid())
  repertoireItemId String
  uploadedByUserId String
  type             RepertoireAttachmentType @default(SHEET_MUSIC)
  storageKey       String
  originalName     String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  repertoireItem RepertoireItem @relation(fields: [repertoireItemId], references: [id], onDelete: Cascade)
  uploadedBy     User           @relation("RepertoireAttachmentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([repertoireItemId, createdAt])
  @@index([uploadedByUserId, createdAt])
}

model PracticeAssignment {
  id                    String                   @id @default(cuid())
  studentId             String
  teacherId             String
  lessonNoteId          String?
  classSessionId        String?
  repertoireItemId      String?
  skillCategoryId       String?
  title                 String
  instructions          String
  assignedDate          DateTime                 @default(now())
  dueDate               DateTime?
  status                PracticeAssignmentStatus @default(ASSIGNED)
  expectedMinutes       Int?
  requiresVideo         Boolean                  @default(false)
  teacherReviewNote     String?
  studentCompletionNote String?
  studentCompletedAt    DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  student        StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher        TeacherProfile  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  lessonNote     LessonNote?     @relation(fields: [lessonNoteId], references: [id], onDelete: SetNull)
  classSession   ClassSession?   @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  repertoireItem RepertoireItem? @relation(fields: [repertoireItemId], references: [id], onDelete: SetNull)
  skillCategory  SkillCategory?  @relation(fields: [skillCategoryId], references: [id], onDelete: SetNull)
  practiceLogs   PracticeLog[]
  practiceVideos PracticeVideo[]

  @@index([studentId, status, dueDate])
  @@index([teacherId, status, dueDate])
  @@index([lessonNoteId])
  @@index([classSessionId])
  @@index([repertoireItemId])
  @@index([skillCategoryId])
}

model PracticeLog {
  id               String   @id @default(cuid())
  studentId        String
  assignmentId     String?
  repertoireItemId String?
  skillCategoryId  String?
  practicedOn      DateTime
  minutesPracticed Int
  notes            String?
  moodRating       Int?
  difficultyRating Int?
  parentNote       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student        StudentProfile      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment     PracticeAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  repertoireItem RepertoireItem?     @relation(fields: [repertoireItemId], references: [id], onDelete: SetNull)
  skillCategory  SkillCategory?      @relation(fields: [skillCategoryId], references: [id], onDelete: SetNull)

  @@index([studentId, practicedOn])
  @@index([assignmentId])
  @@index([repertoireItemId])
  @@index([skillCategoryId])
}

model VideoSkillRating {
  id              String   @id @default(cuid())
  videoFeedbackId String
  skillCategoryId String
  rating          Int
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  videoFeedback VideoFeedback @relation(fields: [videoFeedbackId], references: [id], onDelete: Cascade)
  skillCategory SkillCategory @relation(fields: [skillCategoryId], references: [id], onDelete: Cascade)

  @@unique([videoFeedbackId, skillCategoryId])
  @@index([skillCategoryId])
}

model ProgressReport {
  id                               String               @id @default(cuid())
  reportKey                        String               @unique
  studentId                        String
  teacherId                        String?
  generatedByUserId                String
  publishedByUserId                String?
  startDate                        DateTime
  endDate                          DateTime
  status                           ProgressReportStatus @default(DRAFT)
  generatedAt                      DateTime             @default(now())
  publishedAt                      DateTime?
  archivedAt                       DateTime?
  rubricVersion                    String               @default("default-v1")
  totalScheduledClasses            Int                  @default(0)
  attendanceCount                  Int                  @default(0)
  completedLessonsCount            Int                  @default(0)
  missedLessonsCount               Int                  @default(0)
  cancelledLessonsCount            Int                  @default(0)
  missedCancelledCount             Int                  @default(0)
  singleClassesCount               Int                  @default(0)
  recurringClassesCount            Int                  @default(0)
  lessonNotesCompletedCount        Int                  @default(0)
  missingLessonNotesCount          Int                  @default(0)
  totalPracticeMinutes             Int                  @default(0)
  practiceLogCount                 Int                  @default(0)
  practiceAssignmentCount          Int                  @default(0)
  completedAssignmentCount         Int                  @default(0)
  practiceAssignmentCompletionRate Float                @default(0)
  overdueAssignmentCount           Int                  @default(0)
  videoSubmissionsCount            Int                  @default(0)
  reviewedVideoCount               Int                  @default(0)
  repertoireWorkedCount            Int                  @default(0)
  repertoireCompletedCount         Int                  @default(0)
  averageLessonRating              Float?
  averagePreparednessRating        Float?
  averageFocusRating               Float?
  averageEffortRating              Float?
  averageSkillRatings              Json
  categoryScores                   Json                 @default("{}")
  skillSummary                     Json                 @default("{}")
  attendanceSummary                Json                 @default("{}")
  practiceSummary                  Json                 @default("{}")
  videoSummary                     Json                 @default("{}")
  repertoireSummary                Json                 @default("{}")
  repertoireProgressSummary        Json
  teacherSummary                   String?
  strengths                        String?
  improvementAreas                 String?
  recommendedNextFocus             String?
  finalGrade                       String?
  gradeLetter                      String?
  gradePercentage                  Float?
  adminNote                        String?
  studentVisibleSummary            String?
  createdAt                        DateTime             @default(now())
  updatedAt                        DateTime             @updatedAt

  student     StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher     TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  generatedBy User            @relation("ProgressReportGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: Cascade)
  publishedBy User?           @relation("ProgressReportPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)

  @@index([studentId, startDate, endDate])
  @@index([studentId, status, startDate, endDate])
  @@index([teacherId, createdAt])
  @@index([status, createdAt])
}

model ProgressRecord {
  id              String       @id @default(cuid())
  studentId       String
  level           StudentLevel
  summary         String
  updatedByUserId String
  updatedAt       DateTime     @default(now())

  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  updatedBy User           @relation("ProgressUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Cascade)
}

model LearnedSong {
  id        String   @id @default(cuid())
  studentId String
  title     String
  artist    String
  learnedAt DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Goal {
  id         String   @id @default(cuid())
  studentId  String
  title      String
  targetDate DateTime
  completed  Boolean  @default(false)

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentLogEntry {
  id         String       @id @default(cuid())
  studentId  String
  authorId   String
  type       LogEntryType @default(NOTE)
  title      String
  content    String
  metadata   Json?
  occurredAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  author  User           @relation("StudentLogAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([authorId, createdAt])
  @@index([type, createdAt])
}

model HistoricalImportBatch {
  id              String                      @id @default(cuid())
  studentId       String
  createdByUserId String?
  sourceFilename  String
  sourcePath      String?
  sourceSha256    String
  sourceType      String                      @default("PDF")
  pageCount       Int
  rowCount        Int                         @default(0)
  status          HistoricalImportBatchStatus @default(STAGED)
  environmentNote String?
  dryRun          Boolean                     @default(false)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  student   StudentProfile        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy User?                 @relation("HistoricalImportCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rows      HistoricalImportRow[]

  @@unique([studentId, sourceFilename, sourceSha256])
  @@index([studentId, createdAt])
  @@index([status, createdAt])
}

model HistoricalImportRow {
  id                String                         @id @default(cuid())
  batchId           String
  studentId         String
  sourcePage        Int
  rowHash           String
  rawText           String?
  suggestedType     HistoricalImportSuggestionType @default(UNKNOWN)
  suggestedPayload  Json                           @default("{}")
  confidence        Float                          @default(0)
  status            HistoricalImportRowStatus      @default(STAGED)
  appliedEntityType String?
  appliedEntityId   String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  appliedAt         DateTime?
  errorMessage      String?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  batch      HistoricalImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student    StudentProfile        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy User?                 @relation("HistoricalImportRowReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([batchId, sourcePage, rowHash])
  @@index([batchId, status, sourcePage])
  @@index([studentId, status, createdAt])
  @@index([suggestedType, confidence])
}

model Invitation {
  id               String    @id @default(cuid())
  email            String
  role             Role
  token            String    @unique
  invitedByUserId  String
  acceptedByUserId String?
  studentId        String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  invitedBy  User            @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy User?           @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  student    StudentProfile? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([email, role])
  @@index([invitedByUserId, createdAt])
  @@index([studentId, createdAt])
  @@index([expiresAt])
}

model MessageThread {
  id        String   @id @default(cuid())
  studentId String
  teacherId String
  createdAt DateTime @default(now())

  student  StudentProfile @relation("ThreadStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher  TeacherProfile @relation("ThreadTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([studentId, teacherId])
}

model Message {
  id        String    @id @default(cuid())
  threadId  String
  senderId  String
  content   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ClassReminderDelivery {
  id              String              @id @default(cuid())
  classSessionId  String
  recipientUserId String
  channel         ClassReminderChannel @default(EMAIL)
  offsetMinutes   Int
  scheduledForUtc DateTime
  status          ClassReminderStatus  @default(SENT)
  resendMessageId String?
  errorMessage    String?
  sentAt          DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  recipient    User         @relation("ClassReminderRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, recipientUserId, channel, offsetMinutes])
  @@index([recipientUserId, createdAt])
  @@index([status, createdAt])
}

model ConsentDocument {
  id          String   @id @default(cuid())
  version     String   @unique
  titleEn     String
  titleEs     String
  bodyEn      String
  bodyEs      String
  active      Boolean  @default(false)
  effectiveAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  signatures ConsentSignature[]

  @@index([active, effectiveAt])
}

model ConsentSignature {
  id                 String             @id @default(cuid())
  userId             String
  documentId         String
  signerRole         ConsentSignerRole  @default(PARENT_GUARDIAN)
  signerName         String
  signerRelationship String
  signerEmail        String
  signedAt           DateTime           @default(now())
  locale             String             @default("en")
  ipAddress          String?
  userAgent          String?
  consentTextHash    String
  pdfBytes           Bytes
  pdfSha256          String
  emailStatus        ConsentEmailStatus @default(PENDING)
  resendMessageId    String?
  emailError         String?
  emailSentAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user     User            @relation("ConsentSignedUser", fields: [userId], references: [id], onDelete: Cascade)
  document ConsentDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([userId, signedAt])
  @@index([documentId, signedAt])
  @@index([emailStatus, signedAt])
}

model Invoice {
  id              String    @id @default(cuid())
  studentId       String
  alegraInvoiceId String    @unique
  invoiceNumber   String?
  issueDate       DateTime?
  dueDate         DateTime?
  status          String
  currency        String    @default("USD")
  totalAmount     Decimal?  @db.Decimal(12, 2)
  balanceAmount   Decimal?  @db.Decimal(12, 2)
  viewUrl         String?
  pdfUrl          String?
  lastSyncedAt    DateTime
  rawPayload      Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, issueDate])
  @@index([studentId, status, updatedAt])
}

model InvoiceContactLink {
  id              String                     @id @default(cuid())
  studentId       String                     @unique
  alegraContactId String?
  strategy        InvoiceContactLinkStrategy @default(EMAIL_AUTO)
  lastResolvedAt  DateTime?
  lastError       String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([alegraContactId])
}

model InvoiceSyncRun {
  id                String            @id @default(cuid())
  scope             InvoiceSyncScope
  status            InvoiceSyncStatus @default(RUNNING)
  studentId         String?
  triggeredByUserId String?
  startedAt         DateTime          @default(now())
  finishedAt        DateTime?
  studentsProcessed Int               @default(0)
  studentsFailed    Int               @default(0)
  invoicesUpserted  Int               @default(0)
  errorSummary      String?
  details           Json?
  createdAt         DateTime          @default(now())

  student     StudentProfile? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  triggeredBy User?           @relation("InvoiceSyncTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([scope, status, startedAt])
  @@index([studentId, startedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
